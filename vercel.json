{
  "buildCommand": "npm install && npx vite build",
  "outputDirectory": "public",
  "framework": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.6.2",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "api/index.php"
    }
  ]
}
