{
  "buildCommand": "composer install --prefer-dist --no-dev && npm install && npm run build",
  "outputDirectory": "public",
  "framework": null,
  "installCommand": "composer install --prefer-dist --no-dev",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.5.8",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/build/.+",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/storage/.+",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "api/index.php"
    }
  ]
}
